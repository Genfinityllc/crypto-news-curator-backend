# Frontend Environment Configuration
# Backend API URL - Update this to your production backend URL when deploying
REACT_APP_API_URL=https://crypto-news-curator-backend-production.up.railway.app

# Debug mode (set to true for development)
REACT_APP_DEBUG=true

# Cache refresh interval (in milliseconds) - 5 minutes
REACT_APP_CACHE_REFRESH_INTERVAL=300000
